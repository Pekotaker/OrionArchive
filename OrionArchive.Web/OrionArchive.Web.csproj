    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>5841b596-1ab6-4a31-95cf-fa1a3fbe1ccc</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.0">
