@model OrionArchive.Web.Models.Lecture

@{
    ViewData["Title"] = "Delete Lecture";
}

<h1>Delete Lecture</h1>

<p>Are you sure you want to delete this lecture?</p>

<p>
    <strong>@Model.Title</strong>
</p>

<form asp-action="Delete" asp-route-id="@Model.Id">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId" class="btn btn-secondary">Cancel</a>
</form>